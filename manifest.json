{
  "manifest_version": 3,
  "name": "YouTube Time Manager",
  "version": "2.0.0",
  "description": "Understand your YouTube habits. Track time, discover patterns, get insights.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "YouTube Time Manager"
  },
  "icons": {
    "16": "icon/icon16.png",
    "48": "icon/icon48.png",
    "128": "icon/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*", "https://youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "options.html",
  "permissions": ["storage", "tabs"],
  "host_permissions": ["https://www.youtube.com/*", "https://youtube.com/*"]
}
